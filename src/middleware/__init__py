
'''
Point d'entrée
transforme le dossier en package.
crée l'instance app = Flask(__name__)
initialise la connexion à PostgreSQL.
'''

from flask import Flask
from src.middleware.config import Config

def create_app():
    """Fabrique de l'application Flask (Application Factory)."""
    app = Flask(__name__)
    
    # 1. Charger la configuration centralisée
    app.config.from_object(Config)
    
    # 2. Emplacement pour initialiser la base de données PostgreSQL plus tard
    # db.init_app(app)
    
    # 3. Enregistrer les Blueprints (les routes modulaires)
    from src.middleware.routes import middleware_bp
    app.register_blueprint(middleware_bp)
    
    return app
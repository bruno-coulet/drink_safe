flowchart TD
    %% Définition des styles visuels
    classDef clientStyle fill:#2f80ed,stroke:#1d5ca8,stroke-width:2px,color:#fff;
    classDef frontStyle fill:#f2994a,stroke:#c47123,stroke-width:2px,color:#fff;
    classDef apiStyle fill:#27ae60,stroke:#1e7e43,stroke-width:2px,color:#fff;
    classDef dbStyle fill:#9b51e0,stroke:#7035ab,stroke-width:2px,color:#fff;
    classDef externalStyle fill:#eb5757,stroke:#b83434,stroke-dasharray: 5 5,stroke-width:2px,color:#fff;

    %% ==========================================
    %% COUCHE 1 : PRÉSENTATION (HAUT)
    %% ==========================================
    subgraph Host ["Machine Hôte (Windows / WSL2)"]
        direction TB
        Client["👤 Client Final<br/>(Clé API dans le Header)"]:::clientStyle
        FlaskFront["🌐 Frontend Flask<br/>(Port 5001 - IHM Expert & Client)"]:::frontStyle
    end

    %% ==========================================
    %% COUCHE 2 : MIDDLEWARE & ROUTAGE (MILIEU-HAUT)
    %% ==========================================
    subgraph APISecurity ["Sécurité & Contrôle API (FastAPI - Port 8000)"]
        direction TB
        MiddlewareAuth["🔐 Middleware Auth<br/>(Validation X-API-Key)"]:::apiStyle
        MiddlewareDNS["🛡️ Patch DNS Rebinding<br/>(Surcharge Host Header)"]:::apiStyle
    end

    %% ==========================================
    %% COUCHE 3 : COEUR LOGIQUE MONOLITHE (MILIEU)
    %% ==========================================
    subgraph APIMonolith ["API Unique Modulaire (Conteneur 'api')"]
        direction TB
        subgraph Routes ["Routes / Endpoints FastAPI"]
            direction LR
            RouteClients["/api/clients<br/>(Admin: CRUD & Clés)"]
            RouteData["/api/measurements<br/>(Ingestion & Select)"]
            RoutePredict["/api/predict/all<br/>(Consensus 4 modèles)"]
            RouteOCR["/api/ocr/lab-report<br/>(OCR & Parsing)"]
        end
    end

    %% ==========================================
    %% COUCHE 4 : BASE DE DONNÉES & MLOPS (MILIEU-BAS)
    %% ==========================================
    subgraph DockerNet ["Réseau Interne Docker (Isolé)"]
        direction TB
        PostgresDB[("🐘 PostgreSQL (postgres)<br/>Port 5432<br/>Données métier & Métadonnées MLflow")]:::dbStyle
        MLflowServer["📊 MLflow Server (mlflow)<br/>Port 5000<br/>Gestionnaire d'expériences"]:::dbStyle
        MLopsTraining["⚙️ Pipeline MLOps (mlops-training)<br/>(Conteneur d'entraînement éphémère)"]:::dbStyle
    end

    %% ==========================================
    %% COUCHE 5 : PERSISTANCE PHYSIQUE & EXTERNE (BAS)
    %% ==========================================
    subgraph StorageExternal ["Stockage & Tiers Externes"]
        direction TB
        VolShared["📁 Volume Partagé ./mlruns_artifacts<br/>(Stockage physique des modèles .pkl)"]:::dbStyle
        OCRSpace["☁️ Service OCR.space (Externe Cloud)<br/>(Extraction de texte par IA)"]:::externalStyle
    end

    %% ==========================================
    %% LIAISONS ET FLUX FONCTIONNELS
    %% ==========================================

    %% Flux d'entrée
    Client -- "1. Appel direct (API Key)" --> MiddlewareAuth
    FlaskFront -- "1. Requête HTTP (localhost:8000)" --> MiddlewareAuth

    %% Passage à travers les middlewares de sécurité
    MiddlewareAuth --> MiddlewareDNS
    MiddlewareDNS --> Routes

    %% Interactions avec la base de données
    RouteClients --> PostgresDB
    RouteData --> PostgresDB

    %% Inférence & OCR
    RoutePredict --> MLflowServer
    RouteOCR -- "2. Envoi PDF / Image" --> OCRSpace
    OCRSpace -- "3. Retour texte JSON brut" --> RouteOCR
    RouteOCR -- "4. Enregistrement prélèvement" --> RouteData

    %% Pipeline d'entraînement et MLflow
    MLopsTraining -- "A. Enregistre Runs & Métriques" --> MLflowServer
    MLopsTraining -- "B. Sauvegarde modèles .pkl" --> VolShared

    MLflowServer -- "Stocke métadonnées SQL" --> PostgresDB
    MLflowServer -- "Lit/Écrit artefacts" --> VolShared

    %% ==========================================
    %% CONTRAINTES DE RENDU VERTICALES (LIAISONS INVISIBLES)
    %% ==========================================
    Host ~~~ APISecurity
    APISecurity ~~~ APIMonolith
    APIMonolith ~~~ DockerNet
    DockerNet ~~~ StorageExternal

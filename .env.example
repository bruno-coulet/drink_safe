# Modèle de configuration pour le projet Waterflow 2 - À copier en .env
# Configuration Base de données
DATABASE_URL=postgresql://admin_waterflow:MonMotDePasseSecurise123!@localhost:5432/waterflow_db
POSTGRES_USER=admin_waterflow
POSTGRES_PASSWORD=MonMotDePasseSecurise123!
POSTGRES_DB=waterflow_db

# Configuration MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# --- 1. ACCÈS INTERFACE WEB (FLASK) ---
# Empreintes scrypt à générer avec : uv run scripts/auth/hash_admin_passwords.py
ADMIN_ANALYSTE_PASSWORD_HASH=scrypt:32768:8:1$exemple_hash_ici...
ADMIN_EXPLOITATION_PASSWORD_HASH=scrypt:32768:8:1$exemple_hash_ici...

# --- 2. ACCÈS API BACKEND (FASTAPI) ---
# Clés API initiales (chaînes aléatoires sécurisées) pour amorcer la base de données
ADMIN_ANALYSTE_API_KEY=wf_admin_analyste_XXX_A_REMPLACER
ADMIN_EXPLOITATION_API_KEY=wf_admin_exploitation_YYY_A_REMPLACER